{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Workspace Deck",
  "version": "0.1.0",
  "identifier": "com.workspacedeck.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Workspace Deck",
        "width": 1280,
        "height": 780,
        "minWidth": 860,
        "minHeight": 560,
        "dragDropEnabled": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
